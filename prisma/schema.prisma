generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model Auditoria {
  id               String   @id @default(uuid())
  entidade         String
  registroId       String
  acao             Acao
  dadosRegistrados String
  dataHora         DateTime @default(now())
  registradoPorId  String
  registradoPor    Usuario  @relation("registradoPor", fields: [registradoPorId], references: [id])

  @@index([registroId])
  @@index([dataHora])
  @@map("auditoria")
}

enum Acao {
  CREATE
  UPDATE
  DEACTIVATE
  DELETE
}

model Usuario {
  id                   String      @id @default(uuid())
  cracha               Int?
  nome                 String?
  dataNascimento       DateTime?
  dataAdmissao         DateTime?
  dataDesligamento     DateTime?
  senha                String
  pin                  String
  perfilId             String?
  perfil               Perfil?     @relation("perfil", fields: [perfilId], references: [id])
  turno                TipoTurno?
  escala               TipoEscala?
  empresaId            String?
  empresa              Empresa?    @relation("empresa", fields: [empresaId], references: [id])
  status               Boolean     @default(true)
  gestorComoOperador   Gestor[]    @relation("operador")
  gestorComoSupervisor Gestor[]    @relation("supervisor")
  auditoria            Auditoria[] @relation("registradoPor")

  @@map("usuario")
}

model ContadorDeCracha {
  id        String  @id @default(uuid())
  empresaId String  @unique
  contador  Int
  status    Boolean @default(true)

  @@map("contador_cracha")
}

enum TipoEscala {
  A
  B
  C
  D
}

enum TipoTurno {
  MANHA
  TARDE
  NOITE
}

model Perfil {
  id        String    @id @default(uuid())
  codigo    Int       @default(autoincrement())
  descricao String
  status    Boolean   @default(true)
  usuarios  Usuario[] @relation("perfil")

  @@map("perfil")
}

model Gestor {
  id           String  @id @default(uuid())
  operadorId   String
  operador     Usuario @relation("operador", fields: [operadorId], references: [id])
  supervisorId String
  supervisor   Usuario @relation("supervisor", fields: [supervisorId], references: [id])
  status       Boolean @default(true)

  @@map("gestor")
}

model Empresa {
  id           String    @id @default(uuid())
  codigo       Int       @default(autoincrement())
  cnpj         String    @unique
  razaoSocial  String
  nomeFantasia String
  contato      String
  email        String    @unique
  rua          String
  numero       String
  bairro       String
  cidade       String
  estado       String
  cep          String
  status       Boolean   @default(true)
  usuarios     Usuario[] @relation("empresa")

  @@map("empresa")
}
